{
  "name": "newsvideo",
  "version": "1.0.0",
  "type": "module",
  "description": "報道動画自動生成アプリケーション",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && electron-builder",
    "build:vite": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "prepare:ffmpeg:mac": "node scripts/prepare-ffmpeg.mjs",
    "prebuild": "node scripts/prepare-ffmpeg.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"vite.config.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"vite.config.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aoyaman41/NewsVideo.git"
  },
  "keywords": [
    "electron",
    "react",
    "video",
    "news",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "bugs": {
    "url": "https://github.com/aoyaman41/NewsVideo/issues"
  },
  "homepage": "https://github.com/aoyaman41/NewsVideo#readme",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "mammoth": "^1.11.0",
    "openai": "^6.10.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^7.10.1",
    "zod": "^4.1.13",
    "zustand": "^5.0.9"
  }
}
